# InternIQ Environment Configuration
# -------------------------------------
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── AI Provider (for parsing GitHub internship lists) ─────────────────────────
# Supported providers: gemini | openai
AI_PROVIDER=gemini
# Get a Gemini key at: https://aistudio.google.com/app/apikey (free)
# Get an OpenAI key at: https://platform.openai.com/api-keys
AI_API_KEY=

# ── JSearch API (optional) ────────────────────────────────────────────────────
# Get a free key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month. Leave blank to use GitHub + RemoteOK only.
JSEARCH_API_KEY=

# ── Database (optional) ───────────────────────────────────────────────────────
# Default: SQLite (interniq.db in project root). Works great for local use.
# For PostgreSQL: postgresql://user:password@localhost/interniq
# DATABASE_URL=sqlite:///./interniq.db

# ── App environment ───────────────────────────────────────────────────────────
# Options: development | production
# APP_ENV=development

# ── Server port ───────────────────────────────────────────────────────────────
# Electron overrides this dynamically in production builds.
# PORT=8000
